<Window x:Class="StatHammer.DesktopClient.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StatHammer"
        Height="850"
        Width="1320"
        MinHeight="720"
        MinWidth="1080"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F4F4F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#111827"
                Padding="18,12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="StatHammer"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold" />

                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding CurrentUserDescription}"
                           Foreground="#D1D5DB"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">

                <Border Background="White"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="18"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Параметры симуляции"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,14" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Margin="0,0,12,0">
                                <TextBlock Text="Юнит A"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,5" />

                                <ComboBox ItemsSource="{Binding Units}"
                                          SelectedItem="{Binding SelectedUnitA}"
                                          DisplayMemberPath="Name"
                                          Height="32" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Margin="0,0,12,0">
                                <TextBlock Text="Юнит B"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,5" />

                                <ComboBox ItemsSource="{Binding Units}"
                                          SelectedItem="{Binding SelectedUnitB}"
                                          DisplayMemberPath="Name"
                                          Height="32" />
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Margin="0,0,12,0">
                                <TextBlock Text="Количество симуляций"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,5" />

                                <TextBox Text="{Binding SimulationCount, UpdateSourceTrigger=PropertyChanged}"
                                         Height="32"
                                         Padding="6" />
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Максимум ходов"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,5" />

                                <TextBox Text="{Binding MaxTurns, UpdateSourceTrigger=PropertyChanged}"
                                         Height="32"
                                         Padding="6" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0"
                                      Content="Использовать многопоточность"
                                      IsChecked="{Binding UseParallel}"
                                      VerticalAlignment="Center" />

                            <StackPanel Grid.Column="1"
                                        Margin="0,0,18,0">
                                <TextBlock Text="Количество потоков"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,5" />

                                <TextBox Text="{Binding MaxDegreeOfParallelism, UpdateSourceTrigger=PropertyChanged}"
                                         Height="32"
                                         Padding="6" />
                            </StackPanel>

                            <CheckBox Grid.Column="2"
                                      Content="Сохранить результат в БД"
                                      IsChecked="{Binding SaveResult}"
                                      VerticalAlignment="Center" />

                            <Button Grid.Column="3"
                                    Content="Запустить симуляцию"
                                    Command="{Binding RunSimulationCommand}"
                                    Height="38"
                                    Width="190"
                                    HorizontalAlignment="Right"
                                    Padding="12,5"
                                    FontWeight="SemiBold" />
                        </Grid>

                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#047857"
                                   Margin="0,14,0,0" />

                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#B91C1C"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="White"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="18"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Итог"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,12" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Побед A" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding UnitAWins}" FontSize="20" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Побед B" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding UnitBWins}" FontSize="20" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Ничьих" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Draws}" FontSize="20" />
                            </StackPanel>

                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Среднее число ходов" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding AverageCompletedTurns, StringFormat={}{0:0.###}}"
                                           FontSize="20" />
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Остаток моделей A" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding AverageUnitAFinalAliveModels, StringFormat={}{0:0.###}}"
                                           FontSize="20" />
                            </StackPanel>

                            <StackPanel Grid.Column="5">
                                <TextBlock Text="Остаток моделей B" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding AverageUnitBFinalAliveModels, StringFormat={}{0:0.###}}"
                                           FontSize="20" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{Binding SavedResultDescription}"
                                   Foreground="#4B5563"
                                   Margin="0,12,0,0" />
                    </StackPanel>
                </Border>

                <TabControl>
                    <TabItem Header="По ходам">
                        <DataGrid ItemsSource="{Binding TurnRows}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  MinHeight="250">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Ход"
                                                    Binding="{Binding TurnNumber}" />
                                <DataGridTextColumn Header="Сторона"
                                                    Binding="{Binding Side}" />
                                <DataGridTextColumn Header="Атаки"
                                                    Binding="{Binding AverageAttacks, StringFormat={}{0:0.###}}" />
                                <DataGridTextColumn Header="Попадания"
                                                    Binding="{Binding AverageHits, StringFormat={}{0:0.###}}" />
                                <DataGridTextColumn Header="Пробития"
                                                    Binding="{Binding AverageWounds, StringFormat={}{0:0.###}}" />
                                <DataGridTextColumn Header="Успешные сейвы"
                                                    Binding="{Binding AverageSuccessfulSaves, StringFormat={}{0:0.###}}" />
                                <DataGridTextColumn Header="Урон"
                                                    Binding="{Binding AverageFinalDamage, StringFormat={}{0:0.###}}" />
                                <DataGridTextColumn Header="Убито моделей"
                                                    Binding="{Binding AverageModelsKilled, StringFormat={}{0:0.###}}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="По оружию">
                        <DataGrid ItemsSource="{Binding WeaponRows}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  MinHeight="250">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Ход"
                                                    Binding="{Binding TurnNumber}" />
                                <DataGridTextColumn Header="Сторона"
                                                    Binding="{Binding Side}" />
                                <DataGridTextColumn Header="Оружие"
                                                    Binding="{Binding WeaponName}" />
                                <DataGridTextColumn Header="Профиль"
                                                    Binding="{Binding ProfileName}" />
                                <DataGridTextColumn Header="Среднее количество"
                                                    Binding="{Binding AverageCount, StringFormat={}{0:0.###}}" />
                                <DataGridTextColumn Header="Атаки"
                                                    Binding="{Binding AverageAttacks, StringFormat={}{0:0.###}}" />
                                <DataGridTextColumn Header="Попадания"
                                                    Binding="{Binding AverageHits, StringFormat={}{0:0.###}}" />
                                <DataGridTextColumn Header="Пробития"
                                                    Binding="{Binding AverageWounds, StringFormat={}{0:0.###}}" />
                                <DataGridTextColumn Header="Урон"
                                                    Binding="{Binding AverageFinalDamage, StringFormat={}{0:0.###}}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>