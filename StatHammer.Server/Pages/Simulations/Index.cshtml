@page
@model StatHammer.Server.Pages.Simulations.IndexModel

@{
    ViewData["Title"] = "Симуляции";
}

<h1>Симуляции</h1>

<div class="card">
    <form method="post">
        <div asp-validation-summary="All" class="error"></div>

        <div class="form-row">
            <label asp-for="Input.UnitAId"></label>
            <select asp-for="Input.UnitAId" asp-items="Model.Units">
                <option value="">-- выберите юнит A --</option>
            </select>
            <span asp-validation-for="Input.UnitAId"></span>
        </div>

        <div class="form-row">
            <label asp-for="Input.UnitBId"></label>
            <select asp-for="Input.UnitBId" asp-items="Model.Units">
                <option value="">-- выберите юнит B --</option>
            </select>
            <span asp-validation-for="Input.UnitBId"></span>
        </div>

        <input type="hidden" asp-for="Input.UnitALoadoutUnitId" />
        <input type="hidden" asp-for="Input.UnitBLoadoutUnitId" />  

        <button class="btn btn-secondary" type="submit" asp-page-handler="Loadout">
            Обновить состав
        </button>

        <h2>Loadout</h2>

        <div class="simulation-loadout-grid">
            <fieldset class="fieldset">
                <table class="data-table loadout-table">
                    <thead>
                        <tr>
                            <th>Модель</th>
                            <th>M</th>
                            <th>T</th>
                            <th>Sv</th>
                            <th>W</th>
                            <th>Ld</th>
                            <th>OC</th>
                            <th>Количество</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Input.UnitALoadout.Count; i++)
                        {
                            <tr class="model-stat-row">
                                <td class="model-name-cell">
                                    @Model.Input.UnitALoadout[i].ModelName

                                    <input type="hidden" asp-for="Input.UnitALoadout[i].ModelId" />
                                    <input type="hidden" asp-for="Input.UnitALoadout[i].ModelName" />
                                    <input type="hidden" asp-for="Input.UnitALoadout[i].MinCount" />
                                    <input type="hidden" asp-for="Input.UnitALoadout[i].MaxCount" />

                                    <input type="hidden" asp-for="Input.UnitALoadout[i].Move" />
                                    <input type="hidden" asp-for="Input.UnitALoadout[i].Toughness" />
                                    <input type="hidden" asp-for="Input.UnitALoadout[i].Save" />
                                    <input type="hidden" asp-for="Input.UnitALoadout[i].InvulnerableSave" />
                                    <input type="hidden" asp-for="Input.UnitALoadout[i].Wounds" />
                                    <input type="hidden" asp-for="Input.UnitALoadout[i].Leadership" />
                                    <input type="hidden" asp-for="Input.UnitALoadout[i].OC" />
                                </td>
                                <td>@Model.Input.UnitALoadout[i].Move"</td>
                                <td>@Model.Input.UnitALoadout[i].Toughness</td>
                                <td>@Model.Input.UnitALoadout[i].SaveDisplay</td>
                                <td>@Model.Input.UnitALoadout[i].Wounds</td>
                                <td>@Model.Input.UnitALoadout[i].LeadershipDisplay</td>
                                <td>@Model.Input.UnitALoadout[i].OC</td>
                                <td>
                                    <input class="small-number-input" asp-for="Input.UnitALoadout[i].Count" />
                                    <span asp-validation-for="Input.UnitALoadout[i].Count"></span>
                                </td>
                            </tr>

                            if (Model.Input.UnitALoadout[i].WeaponProfiles.Any())
                            {
                                <tr class="weapon-row">
                                    <td colspan="8">
                                        <table class="weapon-profile-table">
                                            <thead>
                                                <tr>
                                                    <th>Оружие</th>
                                                    <th>Профиль</th>
                                                    <th>Range</th>
                                                    <th>A</th>
                                                    <th>BS/WS</th>
                                                    <th>S</th>
                                                    <th>AP</th>
                                                    <th>D</th>
                                                    <th>Правила</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @for (int w = 0; w < Model.Input.UnitALoadout[i].WeaponProfiles.Count; w++)
                                                {
                                                    <tr>
                                                        <td>@Model.Input.UnitALoadout[i].WeaponProfiles[w].WeaponName</td>
                                                        <td>@(Model.Input.UnitALoadout[i].WeaponProfiles[w].ProfileName ?? "—")</td>
                                                        <td>@Model.Input.UnitALoadout[i].WeaponProfiles[w].RangeDisplay</td>
                                                        <td>@Model.Input.UnitALoadout[i].WeaponProfiles[w].Attacks</td>
                                                        <td>@Model.Input.UnitALoadout[i].WeaponProfiles[w].SkillDisplay</td>
                                                        <td>@Model.Input.UnitALoadout[i].WeaponProfiles[w].Strength</td>
                                                        <td>@Model.Input.UnitALoadout[i].WeaponProfiles[w].ArmorPiercing</td>
                                                        <td>@Model.Input.UnitALoadout[i].WeaponProfiles[w].Damage</td>
                                                        <td>@Model.Input.UnitALoadout[i].WeaponProfiles[w].AbilityDisplay</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>                
            </fieldset>

            <fieldset class="fieldset">
                <table class="data-table loadout-table">
                    <thead>
                        <tr>
                            <th>Модель</th>
                            <th>M</th>
                            <th>T</th>
                            <th>Sv</th>
                            <th>W</th>
                            <th>Ld</th>
                            <th>OC</th>
                            <th>Количество</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Input.UnitBLoadout.Count; i++)
                        {
                            <tr class="model-stat-row">
                                <td class="model-name-cell">
                                    @Model.Input.UnitBLoadout[i].ModelName

                                    <input type="hidden" asp-for="Input.UnitBLoadout[i].ModelId" />
                                    <input type="hidden" asp-for="Input.UnitBLoadout[i].ModelName" />
                                    <input type="hidden" asp-for="Input.UnitBLoadout[i].MinCount" />
                                    <input type="hidden" asp-for="Input.UnitBLoadout[i].MaxCount" />

                                    <input type="hidden" asp-for="Input.UnitBLoadout[i].Move" />
                                    <input type="hidden" asp-for="Input.UnitBLoadout[i].Toughness" />
                                    <input type="hidden" asp-for="Input.UnitBLoadout[i].Save" />
                                    <input type="hidden" asp-for="Input.UnitBLoadout[i].InvulnerableSave" />
                                    <input type="hidden" asp-for="Input.UnitBLoadout[i].Wounds" />
                                    <input type="hidden" asp-for="Input.UnitBLoadout[i].Leadership" />
                                    <input type="hidden" asp-for="Input.UnitBLoadout[i].OC" />
                                </td>
                                <td>@Model.Input.UnitBLoadout[i].Move"</td>
                                <td>@Model.Input.UnitBLoadout[i].Toughness</td>
                                <td>@Model.Input.UnitBLoadout[i].SaveDisplay</td>
                                <td>@Model.Input.UnitBLoadout[i].Wounds</td>
                                <td>@Model.Input.UnitBLoadout[i].LeadershipDisplay</td>
                                <td>@Model.Input.UnitBLoadout[i].OC</td>
                                <td>
                                    <input class="small-number-input" asp-for="Input.UnitBLoadout[i].Count" />
                                    <span asp-validation-for="Input.UnitBLoadout[i].Count"></span>
                                </td>
                            </tr>

                            if (Model.Input.UnitBLoadout[i].WeaponProfiles.Any())
                            {
                                <tr class="weapon-row">
                                    <td colspan="8">
                                        <table class="weapon-profile-table">
                                            <thead>
                                                <tr>
                                                    <th>Оружие</th>
                                                    <th>Профиль</th>
                                                    <th>Range</th>
                                                    <th>A</th>
                                                    <th>BS/WS</th>
                                                    <th>S</th>
                                                    <th>AP</th>
                                                    <th>D</th>
                                                    <th>Правила</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @for (int w = 0; w < Model.Input.UnitBLoadout[i].WeaponProfiles.Count; w++)
                                                {
                                                    <tr>
                                                        <td>@Model.Input.UnitBLoadout[i].WeaponProfiles[w].WeaponName</td>
                                                        <td>@(Model.Input.UnitBLoadout[i].WeaponProfiles[w].ProfileName ?? "—")</td>
                                                        <td>@Model.Input.UnitBLoadout[i].WeaponProfiles[w].RangeDisplay</td>
                                                        <td>@Model.Input.UnitBLoadout[i].WeaponProfiles[w].Attacks</td>
                                                        <td>@Model.Input.UnitBLoadout[i].WeaponProfiles[w].SkillDisplay</td>
                                                        <td>@Model.Input.UnitBLoadout[i].WeaponProfiles[w].Strength</td>
                                                        <td>@Model.Input.UnitBLoadout[i].WeaponProfiles[w].ArmorPiercing</td>
                                                        <td>@Model.Input.UnitBLoadout[i].WeaponProfiles[w].Damage</td>
                                                        <td>@Model.Input.UnitBLoadout[i].WeaponProfiles[w].AbilityDisplay</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>                
            </fieldset>
        </div>

        <h2>Параметры запуска</h2>

        <div class="form-row">
            <label asp-for="Input.SimulationCount"></label>
            <input asp-for="Input.SimulationCount" />
            <span asp-validation-for="Input.SimulationCount"></span>
        </div>

        <div class="form-row">
            <label asp-for="Input.MaxTurns"></label>
            <input asp-for="Input.MaxTurns" />
            <span asp-validation-for="Input.MaxTurns"></span>
        </div>

        <div class="form-row checkbox-row">
            <label asp-for="Input.UseParallel">
                <input asp-for="Input.UseParallel" />
                <span>Использовать многопоточность</span>
            </label>
        </div>

        <div class="form-row">
            <label asp-for="Input.MaxDegreeOfParallelism"></label>
            <input asp-for="Input.MaxDegreeOfParallelism" />
            <span asp-validation-for="Input.MaxDegreeOfParallelism"></span>
        </div>

        <div class="form-row checkbox-row">
            <label asp-for="Input.SaveResult">
                <input asp-for="Input.SaveResult" />
                <span>Сохранить результат в БД</span>
            </label>
        </div>

        <h2>Настройки симуляции</h2>

        <p class="muted">
            Модификаторы применяются к выбранной стороне во время расчёта.
            Положительный Hit/Wound/Save улучшает бросок.
            AP: отрицательное значение усиливает бронепробитие, например -1 делает AP лучше.
        </p>

        <div class="simulation-modifiers-grid">
            <fieldset class="fieldset">
                <legend>Модификаторы юнита A</legend>

                <div class="form-grid">
                    <div class="form-row">
                        <label asp-for="Input.UnitAHitModifier"></label>
                        <input asp-for="Input.UnitAHitModifier" />
                        <span asp-validation-for="Input.UnitAHitModifier"></span>
                    </div>

                    <div class="form-row">
                        <label asp-for="Input.UnitAWoundModifier"></label>
                        <input asp-for="Input.UnitAWoundModifier" />
                        <span asp-validation-for="Input.UnitAWoundModifier"></span>
                    </div>

                    <div class="form-row">
                        <label asp-for="Input.UnitAArmorPiercingModifier"></label>
                        <input asp-for="Input.UnitAArmorPiercingModifier" />
                        <span asp-validation-for="Input.UnitAArmorPiercingModifier"></span>
                    </div>

                    <div class="form-row">
                        <label asp-for="Input.UnitASaveModifier"></label>
                        <input asp-for="Input.UnitASaveModifier" />
                        <span asp-validation-for="Input.UnitASaveModifier"></span>
                    </div>
                </div>
            </fieldset>

            <fieldset class="fieldset">
                <legend>Модификаторы юнита B</legend>

                <div class="form-grid">
                    <div class="form-row">
                        <label asp-for="Input.UnitBHitModifier"></label>
                        <input asp-for="Input.UnitBHitModifier" />
                        <span asp-validation-for="Input.UnitBHitModifier"></span>
                    </div>

                    <div class="form-row">
                        <label asp-for="Input.UnitBWoundModifier"></label>
                        <input asp-for="Input.UnitBWoundModifier" />
                        <span asp-validation-for="Input.UnitBWoundModifier"></span>
                    </div>

                    <div class="form-row">
                        <label asp-for="Input.UnitBArmorPiercingModifier"></label>
                        <input asp-for="Input.UnitBArmorPiercingModifier" />
                        <span asp-validation-for="Input.UnitBArmorPiercingModifier"></span>
                    </div>

                    <div class="form-row">
                        <label asp-for="Input.UnitBSaveModifier"></label>
                        <input asp-for="Input.UnitBSaveModifier" />
                        <span asp-validation-for="Input.UnitBSaveModifier"></span>
                    </div>
                </div>
            </fieldset>
        </div>

        <button class="btn" type="submit" asp-page-handler="Run">
            Запустить симуляцию
        </button>
    </form>
</div>

@if (Model.RunResult?.Result != null)
{
    var result = Model.RunResult.Result;

    <div class="card">
        <h2>Результат</h2>

        @if (Model.RunResult.WasSaved)
        {
            <p class="success">
                Результат сохранён. Id: @Model.RunResult.SavedSimulationResultId
            </p>
        }

        <table class="data-table">
            <tbody>
                <tr>
                    <th>Юнит A</th>
                    <td>@result.UnitAName</td>
                </tr>
                <tr>
                    <th>Юнит B</th>
                    <td>@result.UnitBName</td>
                </tr>
                <tr>
                    <th>Симуляций</th>
                    <td>@result.SimulationCount</td>
                </tr>
                <tr>
                    <th>Побед A</th>
                    <td>@result.UnitAWins</td>
                </tr>
                <tr>
                    <th>Побед B</th>
                    <td>@result.UnitBWins</td>
                </tr>
                <tr>
                    <th>Ничьих</th>
                    <td>@result.Draws</td>
                </tr>
                <tr>
                    <th>Среднее число ходов</th>
                    <td>@result.AverageCompletedTurns.ToString("0.#")</td>
                </tr>
                <tr>
                    <th>Средний остаток моделей A</th>
                    <td>@result.AverageUnitAFinalAliveModels.ToString("0.#")</td>
                </tr>
                <tr>
                    <th>Средний остаток моделей B</th>
                    <td>@result.AverageUnitBFinalAliveModels.ToString("0.#")</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="card">
        <h2>Средняя статистика по ходам</h2>

        <table class="data-table">
            <thead>
                <tr>
                    <th>Ход</th>
                    <th>Сторона</th>
                    <th>Атаки</th>
                    <th>Попадания</th>
                    <th>Пробития</th>
                    <th>Успешные сейвы</th>
                    <th>Урон</th>
                    <th>Убито моделей</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var turn in result.Turns)
                {
                    if (turn.SideA != null)
                    {
                        <tr>
                            <td>@turn.TurnNumber</td>
                            <td>A</td>
                            <td>@turn.SideA.AverageAttacks.ToString("0.#")</td>
                            <td>@turn.SideA.AverageHits.ToString("0.#")</td>
                            <td>@turn.SideA.AverageWounds.ToString("0.#")</td>
                            <td>@turn.SideA.AverageSuccessfulSaves.ToString("0.#")</td>
                            <td>@turn.SideA.AverageFinalDamage.ToString("0.#")</td>
                            <td>@turn.SideA.AverageModelsKilled.ToString("0.#")</td>
                        </tr>
                    }

                    if (turn.SideB != null)
                    {
                        <tr>
                            <td>@turn.TurnNumber</td>
                            <td>B</td>
                            <td>@turn.SideB.AverageAttacks.ToString("0.#")</td>
                            <td>@turn.SideB.AverageHits.ToString("0.#")</td>
                            <td>@turn.SideB.AverageWounds.ToString("0.#")</td>
                            <td>@turn.SideB.AverageSuccessfulSaves.ToString("0.#")</td>
                            <td>@turn.SideB.AverageFinalDamage.ToString("0.#")</td>
                            <td>@turn.SideB.AverageModelsKilled.ToString("0.#")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}