@page
@model StatHammer.Server.Pages.Admin.Abilities.IndexModel

@{
    ViewData["Title"] = "Правила";
}

<h1>Правила</h1>

<div class="card">
    <a class="btn" asp-page="/Admin/Abilities/Create">Добавить правило</a>
    <a class="btn btn-secondary" asp-page="/Admin/Index">Назад в админку</a>
</div>

<div class="card">
    @if (!Model.Abilities.Any())
    {
        <p>Правила пока не добавлены.</p>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Название</th>
                    <th>Используется в профилях оружия</th>
                    <th>Используется в моделях</th>
                    <th>Используется в юнитах</th>
                    <th>Всего использований</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ability in Model.Abilities)
                {
                    <tr>
                        <td>@ability.Id</td>
                        <td>@ability.Name</td>
                        <td>@ability.WeaponProfileUsageCount</td>
                        <td>@ability.ModelUsageCount</td>
                        <td>@ability.UnitUsageCount</td>
                        <td>@ability.TotalUsageCount</td>
                        <td>
                            <a class="btn" asp-page="/Admin/Abilities/Edit" asp-route-id="@ability.Id">Редактировать</a>

                            @if (ability.CanDelete)
                            {
                                <a class="btn btn-danger" asp-page="/Admin/Abilities/Delete" asp-route-id="@ability.Id">Удалить</a>
                            }
                            else
                            {
                                <span class="muted">Удаление запрещено</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>