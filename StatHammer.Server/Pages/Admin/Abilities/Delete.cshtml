@page "{id:int}"
@model StatHammer.Server.Pages.Admin.Abilities.DeleteModel

@{
    ViewData["Title"] = "Удалить правило";
}

<h1>Удалить правило</h1>

<div class="card">
    @if (Model.Ability != null)
    {
        <p>
            Правило:
            <strong>@Model.Ability.Name</strong>
        </p>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <p class="error">@Model.ErrorMessage</p>
        }

        @if (Model.Ability.CanDelete)
        {
            <p>Вы действительно хотите удалить это правило?</p>

            <form method="post">
                <input type="hidden" asp-for="Id" />

                <button class="btn btn-danger" type="submit">Удалить</button>
                <a class="btn btn-secondary" asp-page="/Admin/Abilities/Index">Отмена</a>
            </form>
        }
        else
        {
            <a class="btn btn-secondary" asp-page="/Admin/Abilities/Index">Назад</a>
        }
    }
</div>