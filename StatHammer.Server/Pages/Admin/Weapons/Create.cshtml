@page
@model StatHammer.Server.Pages.Admin.Weapons.CreateModel

@{
    ViewData["Title"] = "Добавить оружие";
}

<h1>Добавить оружие</h1>

<div class="card">
    <form method="post">
        <div asp-validation-summary="All" class="error"></div>

        <div class="form-row">
            <label asp-for="Input.Name"></label>
            <input asp-for="Input.Name" />
            <span asp-validation-for="Input.Name"></span>
        </div>

        <h2>Профили оружия</h2>

        @for (int i = 0; i < Model.Input.Profiles.Count; i++)
        {
            <fieldset class="fieldset">
                <legend>Профиль @(i + 1)</legend>

                <div class="form-grid">
                    <div class="form-row">
                        <label asp-for="Input.Profiles[i].Name"></label>
                        <input asp-for="Input.Profiles[i].Name" />
                        <span asp-validation-for="Input.Profiles[i].Name"></span>
                    </div>

                    <div class="form-row">
                        <label asp-for="Input.Profiles[i].Range"></label>
                        <input asp-for="Input.Profiles[i].Range" />
                        <span asp-validation-for="Input.Profiles[i].Range"></span>
                    </div>

                    <div class="form-row">
                        <label asp-for="Input.Profiles[i].Attacks"></label>
                        <input asp-for="Input.Profiles[i].Attacks" />
                        <span asp-validation-for="Input.Profiles[i].Attacks"></span>
                    </div>

                    <div class="form-row">
                        <label asp-for="Input.Profiles[i].Skill"></label>
                        <input asp-for="Input.Profiles[i].Skill" />
                        <span asp-validation-for="Input.Profiles[i].Skill"></span>
                    </div>

                    <div class="form-row">
                        <label asp-for="Input.Profiles[i].Strength"></label>
                        <input asp-for="Input.Profiles[i].Strength" />
                        <span asp-validation-for="Input.Profiles[i].Strength"></span>
                    </div>

                    <div class="form-row">
                        <label asp-for="Input.Profiles[i].ArmorPiercing"></label>
                        <input asp-for="Input.Profiles[i].ArmorPiercing" />
                        <span asp-validation-for="Input.Profiles[i].ArmorPiercing"></span>
                    </div>

                    <div class="form-row">
                        <label asp-for="Input.Profiles[i].Damage"></label>
                        <input asp-for="Input.Profiles[i].Damage" />
                        <span asp-validation-for="Input.Profiles[i].Damage"></span>
                    </div>
                </div>
            </fieldset>
        }

        <button class="btn" type="submit">Создать</button>
        <a class="btn btn-secondary" asp-page="/Admin/Weapons/Index">Отмена</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}