@page
@model StatHammer.Server.Pages.Admin.Weapons.CreateModel

@{
    ViewData["Title"] = "Добавить оружие";
}

<h1>Добавить оружие</h1>

<div class="card">
    <form method="post">
        <div asp-validation-summary="All" class="error"></div>

        <div class="form-row weapon-name-row">
            <label asp-for="Input.Name"></label>
            <input asp-for="Input.Name" />
            <span asp-validation-for="Input.Name"></span>
        </div>

        <h2>Профили оружия</h2>

        <fieldset class="fieldset weapon-profile-fieldset">
            <legend>Профиль 1</legend>

            <div class="weapon-profile-grid">
                <div class="form-row">
                    <label asp-for="Input.Profiles[0].Name"></label>
                    <input asp-for="Input.Profiles[0].Name" />
                    <span asp-validation-for="Input.Profiles[0].Name"></span>
                </div>

                <div class="form-row">
                    <label asp-for="Input.Profiles[0].Range"></label>
                    <input asp-for="Input.Profiles[0].Range" />
                    <span asp-validation-for="Input.Profiles[0].Range"></span>
                </div>

                <div class="form-row">
                    <label asp-for="Input.Profiles[0].Attacks"></label>
                    <input asp-for="Input.Profiles[0].Attacks" />
                    <span asp-validation-for="Input.Profiles[0].Attacks"></span>
                </div>

                <div class="form-row">
                    <label asp-for="Input.Profiles[0].Skill"></label>
                    <input asp-for="Input.Profiles[0].Skill" />
                    <span asp-validation-for="Input.Profiles[0].Skill"></span>
                </div>

                <div class="form-row">
                    <label asp-for="Input.Profiles[0].Strength"></label>
                    <input asp-for="Input.Profiles[0].Strength" />
                    <span asp-validation-for="Input.Profiles[0].Strength"></span>
                </div>

                <div class="form-row">
                    <label asp-for="Input.Profiles[0].ArmorPiercing"></label>
                    <input asp-for="Input.Profiles[0].ArmorPiercing" />
                    <span asp-validation-for="Input.Profiles[0].ArmorPiercing"></span>
                </div>

                <div class="form-row">
                    <label asp-for="Input.Profiles[0].Damage"></label>
                    <input asp-for="Input.Profiles[0].Damage" />
                    <span asp-validation-for="Input.Profiles[0].Damage"></span>
                </div>

                <div class="form-row">
                    <label asp-for="Input.Profiles[0].AbilityIds"></label>
                    <select asp-for="Input.Profiles[0].AbilityIds"
                            asp-items="Model.Abilities"
                            multiple
                            class="multi-select">
                    </select>
                    <span asp-validation-for="Input.Profiles[0].AbilityIds"></span>
                </div>
            </div>
        </fieldset>

        <div class="checkbox-row second-profile-toggle">
            <input asp-for="Input.HasSecondProfile" id="hasSecondProfile" />
            <label asp-for="Input.HasSecondProfile">Добавить второй профиль оружия</label>
        </div>

        <fieldset class="fieldset weapon-profile-fieldset" id="secondProfileBlock">
            <legend>Профиль 2</legend>

            <div class="weapon-profile-grid">
                <div class="form-row">
                    <label asp-for="Input.Profiles[1].Name"></label>
                    <input asp-for="Input.Profiles[1].Name" />
                    <span asp-validation-for="Input.Profiles[1].Name"></span>
                </div>

                <div class="form-row">
                    <label asp-for="Input.Profiles[1].Range"></label>
                    <input asp-for="Input.Profiles[1].Range" />
                    <span asp-validation-for="Input.Profiles[1].Range"></span>
                </div>

                <div class="form-row">
                    <label asp-for="Input.Profiles[1].Attacks"></label>
                    <input asp-for="Input.Profiles[1].Attacks" />
                    <span asp-validation-for="Input.Profiles[1].Attacks"></span>
                </div>

                <div class="form-row">
                    <label asp-for="Input.Profiles[1].Skill"></label>
                    <input asp-for="Input.Profiles[1].Skill" />
                    <span asp-validation-for="Input.Profiles[1].Skill"></span>
                </div>

                <div class="form-row">
                    <label asp-for="Input.Profiles[1].Strength"></label>
                    <input asp-for="Input.Profiles[1].Strength" />
                    <span asp-validation-for="Input.Profiles[1].Strength"></span>
                </div>

                <div class="form-row">
                    <label asp-for="Input.Profiles[1].ArmorPiercing"></label>
                    <input asp-for="Input.Profiles[1].ArmorPiercing" />
                    <span asp-validation-for="Input.Profiles[1].ArmorPiercing"></span>
                </div>

                <div class="form-row">
                    <label asp-for="Input.Profiles[1].Damage"></label>
                    <input asp-for="Input.Profiles[1].Damage" />
                    <span asp-validation-for="Input.Profiles[1].Damage"></span>
                </div>

                <div class="form-row">
                    <label asp-for="Input.Profiles[1].AbilityIds"></label>
                    <select asp-for="Input.Profiles[1].AbilityIds"
                            asp-items="Model.Abilities"
                            multiple
                            class="multi-select">
                    </select>
                    <span asp-validation-for="Input.Profiles[1].AbilityIds"></span>
                </div>
            </div>
        </fieldset>

        <button class="btn" type="submit">Создать</button>
        <a class="btn btn-secondary" asp-page="/Admin/Weapons/Index">Отмена</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function updateSecondProfileVisibility() {
            const checkbox = document.getElementById('hasSecondProfile');
            const block = document.getElementById('secondProfileBlock');

            if (!checkbox || !block) {
                return;
            }

            block.style.display = checkbox.checked ? 'block' : 'none';
        }

        document.addEventListener('DOMContentLoaded', function () {
            const checkbox = document.getElementById('hasSecondProfile');

            if (checkbox) {
                checkbox.addEventListener('change', updateSecondProfileVisibility);
            }

            updateSecondProfileVisibility();
        });
    </script>
}