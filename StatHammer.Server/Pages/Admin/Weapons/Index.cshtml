@page
@model StatHammer.Server.Pages.Admin.Weapons.IndexModel

@{
    ViewData["Title"] = "Оружие";
}

<h1>Оружие</h1>

<div class="card">
    <a class="btn" asp-page="/Admin/Weapons/Create">Добавить оружие</a>
    <a class="btn btn-secondary" asp-page="/Admin/Index">Назад в админку</a>
</div>

<div class="card">
    @if (!Model.Weapons.Any())
    {
        <p>Оружие пока не добавлено.</p>
    }
    else
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Название</th>
                    <th>Профили</th>
                    <th>Используется моделями</th>
                    <th>Сохранённые результаты</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var weapon in Model.Weapons)
                {
                    <tr>
                        <td>@weapon.Id</td>
                        <td>@weapon.Name</td>
                        <td>
                            @if (!weapon.Profiles.Any())
                            {
                                <span>Нет профилей</span>
                            }
                            else
                            {
                                <table class="nested-table">
                                    <thead>
                                        <tr>
                                            <th>Профиль</th>
                                            <th>Range</th>
                                            <th>A</th>
                                            <th>Skill</th>
                                            <th>S</th>
                                            <th>AP</th>
                                            <th>D</th>
                                            <th>Правила</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var profile in weapon.Profiles)
                                        {
                                            <tr>
                                                <td>@(profile.Name ?? "-")</td>
                                                <td>@(profile.Range == 0 ? "Melee" : profile.Range.ToString())</td>
                                                <td>@profile.Attacks</td>
                                                <td>@profile.Skill+</td>
                                                <td>@profile.Strength</td>
                                                <td>-@profile.ArmorPiercing</td>
                                                <td>@profile.Damage</td>
                                                <td>
                                                    @if (profile.Abilities.Any())
                                                    {
                                                        @string.Join(", ", profile.Abilities)
                                                    }
                                                    else
                                                    {
                                                        <span class="muted">—</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </td>
                        <td>
                            @if (weapon.UsedByModels.Any())
                            {
                                <ul class="compact-list">
                                    @foreach (var modelName in weapon.UsedByModels)
                                    {
                                        <li>@modelName</li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span class="muted">Не используется</span>
                            }
                        </td>
                        <td>@weapon.SimulationResultUsageCount</td>
                        <td>
                            <a class="btn" asp-page="/Admin/Weapons/Edit" asp-route-id="@weapon.Id">
                                Редактировать
                            </a>

                            @if (weapon.CanDelete)
                            {
                                <a class="btn btn-danger" asp-page="/Admin/Weapons/Delete" asp-route-id="@weapon.Id">
                                    Удалить
                                </a>
                            }
                            else
                            {
                                <span class="muted">Удаление запрещено</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>