@page "{id:int}"
@model StatHammer.Server.Pages.Admin.Weapons.DeleteModel

@{
    ViewData["Title"] = "Удалить оружие";
}

<h1>Удалить оружие</h1>

<div class="card">
    @if (Model.Weapon != null)
    {
        <p>
            Оружие:
            <strong>@Model.Weapon.Name</strong>
        </p>

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <p class="error">@Model.ErrorMessage</p>
        }

        @if (Model.Weapon.CanDelete)
        {
            <p>Вы действительно хотите удалить это оружие?</p>

            <form method="post">
                <input type="hidden" asp-for="Id" />

                <button class="btn btn-danger" type="submit">Удалить</button>
                <a class="btn btn-secondary" asp-page="/Admin/Weapons/Index">Отмена</a>
            </form>
        }
        else
        {
            <a class="btn btn-secondary" asp-page="/Admin/Weapons/Index">Назад</a>
        }
    }
</div>