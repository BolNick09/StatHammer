@page
@model StatHammer.Server.Pages.Admin.Users.CreateModel

@{
    ViewData["Title"] = "Создать пользователя";
}

<h1>Создать пользователя</h1>

<div class="card">
    <form method="post">
        <div class="form-row">
            <label asp-for="Input.Email"></label>
            <input asp-for="Input.Email" />
            <span asp-validation-for="Input.Email"></span>
        </div>

        <div class="form-row">
            <label asp-for="Input.Password"></label>
            <input asp-for="Input.Password" type="password" />
            <span asp-validation-for="Input.Password"></span>
        </div>

        <div class="form-row">
            <label asp-for="Input.ConfirmPassword"></label>
            <input asp-for="Input.ConfirmPassword" type="password" />
            <span asp-validation-for="Input.ConfirmPassword"></span>
        </div>

        <button class="btn" type="submit">Создать</button>
        <a class="btn btn-secondary" asp-page="/Admin/Index">Назад</a>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <p class="success">@Model.SuccessMessage</p>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <p class="error">@Model.ErrorMessage</p>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}